.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# local handoff/notes documents (contain secrets)
transfer.md
BLOCKER.md

# stale CLAUDE.md snapshot recreated by external tools (e.g., codex)
AGENTS.md

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# standalone landing page (separate git repo)
web_html/
